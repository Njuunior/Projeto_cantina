PORT=4000
DATABASE_URL=postgresql://postgres:12345@localhost:5432/escola_cantina
JWT_SECRET=troque_este_segredo_em_producao
CLIENT_ORIGIN=http://localhost:5173
# WhatsApp Cloud API (Meta). O REMETENTE é o número ligado a este ID no painel — não é o telefone digitado aqui.
# Pegue Phone number ID e token em: Meta for Developers → seu app → WhatsApp → API Setup.
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_TOKEN=
# Opcional: v21.0 (padrão se vazio)
# WHATSAPP_API_VERSION=v21.0
# 1 = logs no console (por que não enviou, erros da Meta)
WHATSAPP_DEBUG=1
# Teste: força TODAS as notificações para este número (E.164, ex. 5571999477669), ignorando o cadastro do responsável
# WHATSAPP_TEST_OVERRIDE_TO=5571999477669
